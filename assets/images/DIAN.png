Count":0,"subTitle":null,"articleType":"informational","headerImage":[{"url":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-4.jpg","caption":"","alt":""}],"publishedTime":1701866865000,"geoId":10010019,"layoutType":"ARTICLE","authorGroup":"transport-seo","contentType":"article","articleAttribute":{"imageCount":32,"videoCount":0,"wordCount":3241,"experimentTreatment":{},"geoId":10010019,"namespace":"traveloka","layoutType":"ARTICLE","readingTimeSec":1013,"authorGroup":"transport-seo"},"likeApi":{"add":{"fullUrl":"https://api.cnt.traveloka.com/vi-vn/v2/reaction/addReaction","productDomain":"content","path":"/v2/reaction/addReaction","spec":{"reactionType":"LIKE","objectId":"WP_296810","objectType":"ARTICLE"}},"get":{"fullUrl":"https://api.cnt.traveloka.com/vi-vn/v2/reaction/getReactionSummary","productDomain":"content","path":"/v2/reaction/getReactionSummary","spec":{"reactionType":"LIKE","objectId":"WP_296810","objectType":"ARTICLE"}},"remove":{"fullUrl":"https://api.cnt.traveloka.com/vi-vn/v2/reaction/removeReaction","productDomain":"content","path":"/v2/reaction/removeReaction","spec":{"reactionType":"LIKE","objectId":"WP_296810","objectType":"ARTICLE"}}},"metaTag":[{"name":"title","value":"title","content":"Du lịch Dĩ An - Điểm sáng trên bản đồ du lịch tỉnh Bình Dương"}],"articleId":"WP_296810","page_category":"explore-article-destination-flight","pageId":"WP_296810","showBookmark":true,"showAuthor":true,"actionBar":{"like":true,"share":true,"bookmark":true},"message":"Read this article from Traveloka","tags":["du-lich-binh-duong","du-lich-di-an","traveloka-goshare","traveloka-golocal"],"content_owner":"FLIGHT","relatedArticleApi":{"fullUrl":"https://api.cnt.traveloka.com/vi-vn/v2/cms/articles/related","productDomain":"content","path":"/v2/cms/articles/related","spec":null},"showToc":false,"authorName":"Nguyễn Thụy Mộc Nhiên","namespace":"traveloka","headerType":"DEFAULT","headerHeight":"30","authorPicture":"https://ik.imagekit.io/tvlk/blog/2020/01/traveloka-godwit-1.png","publishedDate":"06 Dec 2023","showShare":true,"showLike":true},"viewDescription":[{"id":"o42zSgYB8VxD","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"sps1Obdv88IL","componentName":"Image","type":"VIEW","children":[],"compoundLabel":"FeaturedImage","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-4.jpg?tr=q-70,c-at_max,w-500,h-250,dpr-2","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{}},{"id":"6857e08081f92","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08082529","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Dĩ An là thành phố trực thuộc tỉnh Bình Dương, nằm giáp ranh thành phố Hồ Chí Minh với nhiều tuyến đường huyết mạch như Xa lộ Hà Nội, tuyến đường sắt Bắc – Nam đi qua. Thành phố này mới được công nhận trở thành Đô thị loại II vào tháng 3 năm 2023 nên nơi đây dần trở thành một địa điểm sầm uất, tập trung nhiều dân cư sinh sống, kéo theo đó là nhiều địa điểm tham quan vui chơi giải trí mở ra ngày một nhiều. Vì vậy bây giờ không sợ thiếu gì khi đến Dĩ An chơi cả. Nếu ai đó hỏi bạn Dĩ An có gì chơi thì hãy cùng mình dạo một vòng thành phố thân yêu này nhé!","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08082544","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08082540","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-1.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08082545","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Một trong số nhiều cổng chào của thành phố Dĩ An","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e0808254b","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Để đến được thành phố Dĩ An thì quá là dễ dàng. Từ trung tâm thành phố Hồ Chí Minh chạy theo đường QL 1A hướng về Bình Dương, di chuyển khoảng hơn 15 km là sẽ thấy ngay cổng chào của Thành phố Dĩ An bên đường. Địa điểm đầu tiên mình tới thăm đó là:","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"nh-m-y-xe-l-a-d-an-6857e08083a71","componentName":"ScrollToContainer","type":"VIEW","children":[{"id":"6857e08082550","componentName":"Title","type":"VIEW","children":[],"validations":[],"text":"Nhà máy xe lửa Dĩ An","style":"headline","styleSheet":{"color":"#333333","marginBottom":0,"fontSize":32,"lineHeight":48,"marginTop":32,"fontWeight":"600"}}],"validations":[]},{"id":"6857e08083a84","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Địa chỉ: Đường Lý Thường Kiệt, Khu phố 1, Dĩ An, Bình Dương.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083a8a","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Định vị trên Google map với cái tên Công viên Toa xe lửa. Mở cửa tự do với giá vé 0 đồng.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083a8e","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Đây chính là nhà máy xe lửa đầu tiên ở khu vực miền Nam được xây dựng trong giai đoạn dưới ách đô hộ của thực dân Pháp và đảm nhiệm việc bảo trì sửa chữa ra đầu máy toa xe cho các tuyến đường sắt Bắc - Nam.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083a9a","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083a97","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-2.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083a9b","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Trở về thập niêm xưa với toa xe lửa cổ","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083aa0","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Nhà máy xe lửa Bình Dương còn được gọi là Nhà máy xe lửa Dĩ An có vị trí nằm trên một ngọn đồi đất cao, được thực dân Pháp xây dựng từ những năm 1902 đồng hành cùng tuyến đường sắt Bắc - Nam và hoạt động đến tận ngày này. Điểm du lịch Dĩ An này mang một giá trị lịch sử to lớn, ghi lại biết bao dấu ấn của nhiều sự kiện lịch sử cùng với sự hình thành, phát triển của giai cấp công nhân và cũng là nơi ra đời của chi bộ Đảng đầu tiên.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083aa9","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083aa7","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-3.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083aaa","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Cả toa tàu nổi bật giữa 1 công viên rộng lớn","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083aae","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Với bề dày lịch sử lên đến hơn 100 năm, tại địa điểm check-in này mang một giá trị nhân văn sâu sắc này đã từng là nơi trỗi dậy của biết bao thế hệ từ những người thợ của nhà máy luôn tiên phong trong mọi phong trào kêu gọi đấu tranh giành độc lập. Bên cạnh đó, Chi bộ Đảng đầu tiên của Xứ uỷ Nam kỳ cũng được đánh dấu và ra đời tại đây.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083ab4","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Vào thời kỳ đó, có thể nói Nhà máy xe lửa Bình Dương là nhà máy lớn nhất trong ngành đường sắt Việt Nam. Nơi đây giữ vai trò cực kỳ quan trọng trong việc phát triển của giao thông đường bộ. Bởi vào những năm thế kỷ 20 các phương tiện di chuyển còn rất hạn chế, xe lửa có thể nói là phương tiện duy nhất để liên tỉnh, qua đó thấy được vai trò của Nhà máy xe lửa Bình Dương trong việc sửa chữa đầu máy, sản xuất toa xe cũng như thiết lập đường ray.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083abd","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083abb","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-4.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083abe","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Đến Nhà máy xe lửa Bình Dương để tìm hiểu về di tích lịch sử trải qua biết bao sự kiện trong giai đoạn trường kỳ kháng chiến","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083ac2","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083ac1","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-5.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083ac9","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083ac7","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-6.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083aca","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Biểu tượng của ngành cơ khí đặc biệt của Nhà máy xe lửa Bình Dương","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083ace","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Nhà máy xe lửa Bình Dương là nơi lưu giữ lại những nhà xưởng, đầu máy xe lửa, đầu máy hơi nước,... từ thời kỳ đầu tiên vẫn còn nguyên vẹn nơi đây. Nơi đây được xem như là cái nôi nuôi dưỡng của ngành đường sắt Việt Nam và trở thành di tích lịch sử được tỉnh uỷ công nhận.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083ade","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083adc","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-7.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083adf","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Lũ trẻ gần đây thường chạy ra đây chơi mình rủ chụp hình cùng","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083ae3","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Bên cạnh đó, nhà máy xe lửa Bình Dương còn ghi dấu những chặng đường đã qua và là điểm đến ý nghĩa trên bản đồ du lịch Dĩ An - Bình Dương, được người dân nơi đây tự hào mỗi lần nhắc đến. Đến đây để hiểu hơn về những câu chuyện của một giai cấp công nhân dưới ách đô hộ, vượt bao khó khăn gian khổ để có được như ngày nay.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083aea","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Khuôn viên Nhà máy xe lửa Bình Dương khá rộng lớn đến 20.000 mét vuông, được xây dựng trong suốt hơn 10 năm trời để hoàn thiện. Hiện tại bên ngoài đang là 1 khu công viên rộng lớn trưng bày cả toa tàu xe lửa cũ, bên trong là hệ thống nhà xưởng của từng bộ phần như: chế tạo, lắp ráp, bảo trì, sửa chưa, sơn dầu,... Hiên nay, mỗi năm Nhà máy xe lửa Bình Dương tạo mới và sửa chữa hàng trăm toa tàu mang lại nhiều lợi ích cho ngành đường sắt Việt Nam và là cả sự tự hào của người dân Dĩ An. Là di tích lịch sử cách mạng cấp tỉnh được công nhận vào ngày 25/12/2012.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"con-ng-b-ch-h-a-d-an-6857e08083b1a","componentName":"ScrollToContainer","type":"VIEW","children":[{"id":"6857e08083aee","componentName":"Title","type":"VIEW","children":[],"validations":[],"text":"Con đường Bích họa Dĩ An","style":"headline","styleSheet":{"color":"#333333","marginBottom":0,"fontSize":32,"lineHeight":48,"marginTop":32,"fontWeight":"600"}}],"validations":[]},{"id":"6857e08083b1f","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Địa chỉ: Đường Nguyễn An Ninh, Dĩ An, Bình Dương","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083b24","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Tiếp đến mình rất ấn tượng với Dự án “Thay áo mới cho tường cũ” được Thành Đoàn Dĩ An và Phòng Giáo dục – Đào tạo thành phố phối hợp thực hiện tại con đường Nguyễn An Ninh (bức tường trước khu vực Nhà ga Dĩ An) nhằm đem lại một vẻ đẹp mới cho toàn thành phố.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083b2d","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083b2b","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-8.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083b2e","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Khu vực chờ xe bus trở nên có hồn hơn nhờ Bức tường bích họa","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083b32","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Những bức tường vô tri đã được các bạn đoàn viên thanh niên “thổi hồn” bằng những bức tranh sinh động nhiều màu sắc với những hình ảnh về con người, quê hương Dĩ An thân thương, cùng những biểu ngữ tuyên truyền ,…khiến ai đi qua cũng trầm trồ khen ngợi. Đây có thể được coi như là Con đường bích họa Dĩ An - trở thành điểm du lịch Dĩ An không thể bỏ qua.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083b3a","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083b38","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-9.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083b3b","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Nguyên một con đường Nguyễn An Ninh dài đều được tổ điểm rực rỡ","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083b3e","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Việc thực hiện công trình Con đường bích họa này đã góp phần không nhỏ trong việc cải thiện cảnh quan đô thị trên địa bàn thành phố Dĩ An, tạo nên vẻ đẹp tươi mới trở thành một bức tranh đa sắc, độc đáo trên cả tuyến đường phố.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083b44","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083b42","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-10.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083b4d","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083b49","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-11.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083b4e","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Bức tường đầy ý nghĩa với nhiều bức tranh cổ động giáo dục.","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083b51","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Theo mình được biết, mô hình này đã được nhân rộng và nhận được sự lan tỏa, hưởng ứng tích cực của các cơ sở Đoàn và đoàn viên thanh niên Dĩ An và không chỉ dừng lại trên tuyến đường này mà còn được thay áo mới cho thùng rác, ghế đá, cột điện… ” trên các tuyến đường thuộc các phường Bình An, Bình Thắng, An Bình và Đông Hòa.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"nh-ng-c-ng-vi-n-m-i-d-an-6857e08083b7c","componentName":"ScrollToContainer","type":"VIEW","children":[{"id":"6857e08083b55","componentName":"Title","type":"VIEW","children":[],"validations":[],"text":"Những công viên mới Dĩ An","style":"headline","styleSheet":{"color":"#333333","marginBottom":0,"fontSize":32,"lineHeight":48,"marginTop":32,"fontWeight":"600"}}],"validations":[]},{"id":"6857e08083b82","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Dạo một vòng du lịch Dĩ An có thể nhận thấy rằng thành phố này có khá nhiều Công viên ở nhiều khu vực khác nhau, rất nhiều trong số đó đều là mới được khánh thành đưa vào sử dụng. Và sau khi tìm hiểu mình biết được rằng hiện tại thành phố đang triển khai xây dựng, phát triển theo hướng văn minh, hiện đại. Những năm qua thành phố không chỉ tập trung đầu tư xây dựng cơ sở hạ tầng mà song song đó còn chú trọng đầu tư xây dựng các công viên, tiểu cảnh, chuyển đổi công năng các khu đất công thực hiện xây dựng công viên, tiểu cảnh, góp phần tạo không gian sinh hoạt của người dân, tạo mỹ quan đô thị.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083b8d","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083b8b","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-12.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083b8e","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Một Công viên rộng lớn nằm trước cơ quan hành chính thành phố","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083b92","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Đầu tiên có thể kể đến Công viên Dĩ an nằm ở một khuôn viên trước Ủy ban hành chính thành phố Dĩ An hay còn gọi là Công viên Khu hành chính Dĩ An. Với không gian khá là rộng lớn kết hợp với nhiều cây xanh tạo nên một không gian xanh yên tĩnh, mát mẻ, đây là nơi mọi người có thể thư giãn và tập thể dục sau một ngày làm việc căng thẳng, mệt nhọc.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083b97","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Địa chỉ tại Đường Số 9, P. Dĩ An, Dĩ An. Bình Dương.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083b9e","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083b9c","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-13.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083b9f","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Khoảng sân này một lát sau trở thành điểm vui chơi giải trí tấp nập người dân","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083ba4","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083ba2","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-14.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083ba5","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Công viên này là nơi tổ chức diễn ra nhiều sự kiện lớn cấp thành phố","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083ba9","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083ba7","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-15.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":2