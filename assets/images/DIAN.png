ể mọi người tập thể dục thể thao hay chỉ ngồi nghỉ trên rất nhiều ghế đá trong công viên dưới tán cây cũng đủ để thư giãn sau 1 ngày làm việc mệt mỏi.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083bce","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083bca","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-19.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083bcf","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Tấp nập tiếng cười nói của lũ trẻ cảm giác như đang ở vùng quê thân quen nhưng lại là trung tâm của 1 thành phố đang phát triển","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083bd3","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083bd1","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-20.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083bd7","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083bd6","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-21.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083bdc","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083bdb","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-22.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083bdd","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Check in với ánh nắng chiều tại đây đầy thư giãn","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083be0","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Công viên Rạp hát Dĩ An có quy mô nhỏ hơn nhiều so với 2 Công viên phía trên nhưng lại nằm ở vị trí đắc địa sầm uất nên thường được làm nơi tổ chức những sự kiện trong khu vực địa bàn thành phố. Công viên này được xây dựng trên khu vực nhà hát Dĩ An trước đây.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083be6","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083be4","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-23.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083bec","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083beb","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-24.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083bed","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Là một công viên bé để nghỉ chân của các tay phượt chạy quãng đường xa","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083bf2","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083bf0","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-25.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083bf3","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Nhiều mã QR đặt khắp các công viên để quảng bá du lịch cho TP.Dĩ An","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083bf8","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083bf6","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-26.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083bf9","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Công viên nào cũng mang lại cảm giác yên bình, thư giãn","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083bfc","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Sau khi có thêm những Công viên được đưa vào sử dụng phục vụ đời sống người dân và làm nơi chốn nghỉ chân cho những chuyến phượt xa thì các hàng quán, dịch vụ lề đường mọc lên nhiều, các dịch vụ cho thuê xe hơi trẻ em, trượt patin, karaoke cũng từ đó phát triển. Tất cả góp phần mang lại cho Thành phố mới được công nhận là Đô thị Loại II trở nên sôi động, nhộn nhịp và phát triển hơn.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"khu-vui-ch-i-trung-t-m-h-nh-ch-nh-d-an-6857e08083c26","componentName":"ScrollToContainer","type":"VIEW","children":[{"id":"6857e08083c00","componentName":"Title","type":"VIEW","children":[],"validations":[],"text":"Khu vui chơi trung tâm hành chính Dĩ An","style":"headline","styleSheet":{"color":"#333333","marginBottom":0,"fontSize":32,"lineHeight":48,"marginTop":32,"fontWeight":"600"}}],"validations":[]},{"id":"6857e08083c2b","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Địa chỉ: Đường số 9/ Đường A, Khu hành chính Dĩ An, TP. Dĩ An","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083c2f","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Trên trục đường với Công viên Khu hành chính Dĩ An","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083c33","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Đây là một khu tổ hợp ăn uống, vui chơi, mua sắm rộng lớn của trung tâm thành phố Dĩ An. Có thể nói rằng bất cứ ai ở đây cũng đều biết đến địa điểm này. Cảm giác khi mình tới đây dường như cả tuổi thơ ùa về vậy với những trò chơi là cả kí ức vui vẻ ngày xưa bé con. Đây đúng là mô hình tổ hợp mà ngày bé chúng ta thường lui tới. Khu vui chơi giải trí này đã có từ rất lâu và trở thành điểm đến vui chơi có tiếng của toàn thành phố.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083c3d","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083c3b","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-27.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083c3e","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Xin chào tới Khu vui chơi giải trí Dĩ An","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083c43","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083c42","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-28.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083c44","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Bán một tấm vé quay trở về tuổi thơ nào","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083c48","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Một sân chơi ăn uống mua sắm cho cả bé lẫn ba mẹ đều có thể đến để giải trí sau ngày dài mệt mỏi. Hơn 20 trò chơi, khu ăn uống và mua sắm nằm phân chia theo từng khu vực của Khu vui chơi này. Đặc biệt giá vé mỗi trò chơi cực kì rẻ, chỉ dao động từ 10.000đ đến 20.000đ, và có thể cả người lớn và trẻ nhỏ chơi cùng được. Thế này thì cả gia đình đều có thể tham gia hoạt động vui chơi cùng nhau được.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083c4f","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083c4d","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-29-768x1024.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083c54","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083c53","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-30.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083c55","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Rất nhiều trò chơi tuổi thơ vẫn đang hoạt động mỗi ngày tại đây","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083c59","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Những trò chơi đơn giản nhưng đủ để khiến tụi nhỏ cười nói rôm rả bên ba mẹ của mình. Ở trong khung cảnh này ngắm nhìn tụi nhỏ chạy nhảy chơi đùa cũng giúp bạn yêu đời hơn rồi. Chưa kể bạn có thể tham gia vui đùa cùng trong chuyến du lịch Dĩ An này nữa. Không có quá nhiều nơi còn lưu giữ được những trò chơi đơn giản như thế này như bây giờ. Nhưng đó là cả một tuổi thơ của chúng ta đã từng được hạnh phúc khi mẹ thưởng cho ra đây chơi mỗi khi học giỏi.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083c60","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083c5e","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-31.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083c66","componentName":"VerticalContainer","type":"VIEW","children":[{"id":"6857e08083c64","componentName":"Image","type":"VIEW","children":[],"backgroundColor":"transparent","validations":[],"imageUrl":"https://ik.imagekit.io/tvlk/blog/2023/11/go-and-share-du-lich-di-an-binh-duong-32.jpg?tr=q-70,c-at_max,w-1000,h-600","alt":"du lịch Dĩ An","styleSheet":{"marginRight":"auto","overflow":"hidden","borderRadius":20,"maxHeight":400,"width":"auto","marginBottom":8,"marginTop":20,"maxWidth":"100%","marginLeft":"auto"}},{"id":"6857e08083c67","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Chơi đủ mệt với rất nhiều trò chơi ở đây","style":"uiSmall","styleSheet":{"marginBottom":0,"marginTop":0},"styleSheetGroup":{"text":{"color":"#777","textAlign":"center","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{"overflow":"hidden","maxHeight":450,"marginTop":0}},{"id":"6857e08083c6b","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Ngoài ra còn có những quầy bán đồ ăn nhanh. Với những xiên cá viên chiên, bánh tráng nướng, trà tắc, trà sữa… Buổi tối ra đây ngồi tám chuyện hóng gió ăn no nê mà giá thì cực hợp lý chỉ từ 5.000đ đến 15.000đ là đã có cá viên chiên ăn, thêm ly nước chỉ 25.000đ nữa hay bánh tráng nướng 15.000đ. Tối đến thì khu vực này nhộn nhịp rộn ràng","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083c70","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"Có thể hiện tại Dĩ An chưa phải là địa điểm du lịch nổi tiếng nhưng Dĩ An có tiềm năng du lịch với vẻ đẹp truyền thống, giá trị văn hóa lịch sử đan xen với vẻ đẹp của sự phát triển hội nhập của thành phố. Trong tương lai gần hứa hẹn du lịch Dĩ An sẽ trở thành một điểm sáng du lịch của tỉnh Bình Dương.","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083c75","componentName":"Paragraph","type":"VIEW","children":[],"validations":[],"htmlText":"\u003cstrong\u003eTác giả: Nguyễn Đăng Khoa\u003cbr\u003e*Bài viết tham gia chương trình Traveloka Golocal\u003c/strong\u003e","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}},{"id":"6857e08083c78","componentName":"VerticalContainer","type":"VIEW","children":[],"marginTop":16,"marginBottom":24,"marginLeft":24,"marginRight":24,"backgroundColor":"#cdd0d1","height":1,"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{}},{"id":"6857e08083c83","componentName":"Paragraph","type":"VIEW","children":[],"trackingSpec":{"click":{"articleTitle":"Thành phố Dĩ An - Điểm sáng trên bản đồ du lịch Bình Dương","articleId":"WP_296810","destination":"https://www.traveloka.com/vi-vn/go-and-share","articleCategory":"vietnam,golocal","eventName":"CLICK_HYPERLINK","layoutType":"ARTICLE","authorGroup":"transport-seo","contentType":"article"}},"validations":[],"htmlText":"\u003cstrong\u003eTraveloka Golocal\u003c/strong\u003e là chương trình viết blog giới thiệu những địa điểm đẹp trên khắp đất nước Việt Nam, thuộc khuôn khổ chương trình \u003ca target=\"_blank\" rel=\"noreferrer noopener\" href=\"https://www.traveloka.com/vi-vn/go-and-share?funnel_source=content_article\u0026funnel_id=WP_296810\" \u003eTraveloka Go \u0026 Share\u003c/a\u003e. Đây là cơ hội tuyệt vời để quảng bá du lịch địa phương đến mọi người. Với mỗi bài viết đạt yêu cầu bạn sẽ nhận ngay \u003cstrong\u003e800.000 VND\u003c/strong\u003e và cơ hội làm Cộng tác viên với Traveloka. Thông tin chi tiết về chương trình xem tại:\u003ca target=\"_blank\" rel=\"noreferrer noopener\" href=\"https://trv.lk/golocal?funnel_source=content_article\u0026funnel_id=WP_296810\" \u003e https://trv.lk/golocal\u003c/a\u003e","style":"uiBaseline","styleSheet":{"marginBottom":0,"marginTop":20},"styleSheetGroup":{"text":{"color":"#333333","fontWeight":"400"}}}],"validations":[],"separator":false,"enableWebToAppRedirection":false,"styleSheet":{}},{"id":"jbslbmniqMfI","componentName":"Verti